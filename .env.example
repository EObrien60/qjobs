# Postgres connection string for the SaaS database that owns the platform.* tables
DATABASE_URL=postgres://postgres:postgres@localhost:5432/qjobs_dev

# Unique id for this worker instance (used in locked_by). Defaults to workerd-<pid>.
WORKERD_INSTANCE_ID=workerd-local-1

# Poll loop interval in milliseconds (default 1000)
WORKERD_POLL_INTERVAL_MS=1000

# Rows claimed per tick (default 50)
WORKERD_BATCH_SIZE=50

# Max jobs processed concurrently within one worker (default 5)
WORKERD_MAX_CONCURRENCY=5

# debug | info | warn | error (default info)
WORKERD_LOG_LEVEL=info

# Logical product/service name recorded on jobs and used for idempotency scope (default workerd)
WORKERD_SOURCE=qhaul

# Optional: expose GET /healthz and GET /readyz on this port. Omit to disable.
WORKERD_HEALTH_PORT=8082
